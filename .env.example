# BSC RPC endpoint (use a private RPC for lower latency)
# Free options: https://bsc-dataseed1.binance.org/
# Private options: QuickNode, Alchemy, GetBlock
RPC_URL=https://bsc-dataseed1.binance.org/

# WebSocket endpoint for real-time block/event monitoring
WSS_URL=wss://bsc-dataseed1.binance.org:8546

# Your BSC wallet credentials (NEVER commit real values!)
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# BSCScan API key for contract ABI and source-code fetching
# Get a free key at https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# SQLite database file path for transaction history
DB_PATH=data/monitor.db

# Minimum BNB liquidity to consider a token safe (default: 5)
MIN_LIQUIDITY_BNB=5

# Maximum sell tax percentage to consider a token safe (default: 10)
MAX_SELL_TAX_PERCENT=10

# Comma-separated list of trusted/whitelisted creator addresses
WHITELISTED_CREATORS=

# Amount of BNB to use per buy transaction (default: 0.05)
BUY_AMOUNT_BNB=0.05

# Gas price multiplier for priority transactions (default: 1.2)
GAS_PRICE_MULTIPLIER=1.2

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
